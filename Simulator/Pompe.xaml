<UserControl x:Class="Simulator.Pompe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" Height="848" Width="1159">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="ControlButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SimButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1A1A2E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="210"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="0"/>
        </Grid.RowDefinitions>

        <!-- TITLU -->
        <TextBlock
                   Text="Sistem pompe ape uzate (M44)"
                   FontSize="18" FontWeight="Bold" Foreground="#E0E0E0"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="418,0,0,0" Height="23" Width="263"/>

        <!-- ZONA PRINCIPALA -->
        <Canvas Grid.Row="1" Grid.Column="0" Background="#1A1A2E" Margin="10,0,5,0">

            <!-- === CONDUCTA INTRARE === -->
            <TextBlock Canvas.Left="8" Canvas.Top="108" Text="U1" Foreground="#AAAAAA" FontSize="11"/>
            <Line X1="30" Y1="115" X2="72" Y2="115" Stroke="#777777" StrokeThickness="4"/>
            <Ellipse Canvas.Left="32" Canvas.Top="120" Width="16" Height="12"
                     Stroke="#AAAAAA" StrokeThickness="1" Fill="Transparent"/>
            <TextBlock Canvas.Left="36" Canvas.Top="122" Text="P" Foreground="#AAAAAA" FontSize="9"/>
            <Path Stroke="#777777" StrokeThickness="4" Fill="Transparent"
                  Data="M72,115 Q72,75 112,75 L178,75"/>
            <Polygon Points="178,68 193,75 178,82" Fill="#AAAAAA"/>
            <Polygon Points="208,68 193,75 208,82" Fill="#AAAAAA"/>
            <Line X1="193" Y1="68" X2="193" Y2="60" Stroke="#AAAAAA" StrokeThickness="2"/>
            <Line X1="185" Y1="60" X2="201" Y2="60" Stroke="#AAAAAA" StrokeThickness="2"/>
            <TextBlock Canvas.Left="187" Canvas.Top="48" Text="Y" Foreground="#AAAAAA" FontSize="10"/>
            <Path Stroke="#777777" StrokeThickness="4" Fill="Transparent"
                  Data="M208,75 L242,75 L242,120"/>

            <!-- === BAZIN === -->
            <Rectangle Canvas.Left="120" Canvas.Top="120" Width="460" Height="280"
                       Stroke="#555555" StrokeThickness="2" Fill="#0A1520"/>

            <!-- NIVELUL APEI ANIMAT -->
            <Rectangle Canvas.Left="122" Width="456"
                       Fill="#1A4A7A" Opacity="0.9"
                       Height="{Binding WaterLevel}"
                       Canvas.Top="{Binding WaterTop}"/>
            <!-- Suprafata apei -->
            <Rectangle Canvas.Left="122" Width="456" Height="4"
                       Fill="#3A8AC0" Opacity="0.9"
                       Canvas.Top="{Binding WaterTop}"/>

            <!-- === BARA NIVEL === -->
            <Rectangle Canvas.Left="318" Canvas.Top="125" Width="26" Height="270"
                       Stroke="#444444" StrokeThickness="1" Fill="Transparent"/>
            <Line X1="318" Y1="160" X2="344" Y2="160" Stroke="#444444" StrokeThickness="1"/>
            <Line X1="318" Y1="220" X2="344" Y2="220" Stroke="#444444" StrokeThickness="1"/>
            <Line X1="318" Y1="280" X2="344" Y2="280" Stroke="#444444" StrokeThickness="1"/>
            <Line X1="318" Y1="320" X2="344" Y2="320" Stroke="#444444" StrokeThickness="1"/>
            <Line X1="318" Y1="360" X2="344" Y2="360" Stroke="#444444" StrokeThickness="1"/>
            <Rectangle Canvas.Left="320" Width="22"
                       Fill="#3A8AC0" Opacity="0.75"
                       Height="{Binding WaterLevel}"
                       Canvas.Top="{Binding WaterTop}"/>

            <!-- ============================================================ -->
            <!-- SENZORI - Canvas.Top = 400 - LevelBx                        -->
            <!-- B1=30→370, B2=100→300, B4=80→320, B5=180→220, B3=240→160   -->
            <!-- ============================================================ -->

            <!-- B3 nivel critic (rosu) Canvas.Top=160 -->
            <TextBlock Canvas.Left="125" Canvas.Top="155" Text="B3"
                       Foreground="#EF4444" FontSize="11" FontWeight="Bold"/>
            <Line X1="148" Y1="165" X2="164" Y2="165" Stroke="#EF4444" StrokeThickness="1.5"/>
            <Line X1="148" Y1="171" X2="164" Y2="171" Stroke="#EF4444" StrokeThickness="1.5"/>
            <Ellipse Canvas.Left="160" Canvas.Top="162" Width="10" Height="10"
                     Stroke="#EF4444" StrokeThickness="1.5" Fill="Transparent"/>
            <Line X1="122" Y1="168" X2="580" Y2="168" Stroke="#EF4444"
                  StrokeThickness="0.5" StrokeDashArray="6,4" Opacity="0.5"/>
            <TextBlock Canvas.Left="590" Canvas.Top="162" Text="↑ CRITIC"
                       Foreground="#EF4444" FontSize="9" Opacity="0.7"/>

            <!-- B5 pornire P2 (portocaliu) Canvas.Top=220 -->
            <TextBlock Canvas.Left="588" Canvas.Top="215" Text="B5"
                       Foreground="#F59E0B" FontSize="11" FontWeight="Bold"/>
            <Line X1="578" Y1="225" X2="590" Y2="225" Stroke="#F59E0B" StrokeThickness="1.5"/>
            <Line X1="578" Y1="231" X2="590" Y2="231" Stroke="#F59E0B" StrokeThickness="1.5"/>
            <Ellipse Canvas.Left="574" Canvas.Top="222" Width="10" Height="10"
                     Stroke="#F59E0B" StrokeThickness="1.5" Fill="Transparent"/>
            <Line X1="122" Y1="228" X2="580" Y2="228" Stroke="#F59E0B"
                  StrokeThickness="0.5" StrokeDashArray="6,4" Opacity="0.5"/>
            <TextBlock Canvas.Left="125" Canvas.Top="222" Text="↑ pornire P2"
                       Foreground="#F59E0B" FontSize="9" Opacity="0.7"/>

            <!-- B2 pornire P1 (verde) Canvas.Top=300 -->
            <TextBlock Canvas.Left="82" Canvas.Top="294" Text="B2"
                       Foreground="#22C55E" FontSize="11" FontWeight="Bold"/>
            <Line X1="108" Y1="305" X2="120" Y2="305" Stroke="#22C55E" StrokeThickness="1.5"/>
            <Line X1="108" Y1="311" X2="120" Y2="311" Stroke="#22C55E" StrokeThickness="1.5"/>
            <Ellipse Canvas.Left="116" Canvas.Top="302" Width="10" Height="10"
                     Stroke="#22C55E" StrokeThickness="1.5" Fill="Transparent"/>
            <Line X1="122" Y1="308" X2="580" Y2="308" Stroke="#22C55E"
                  StrokeThickness="0.5" StrokeDashArray="6,4" Opacity="0.5"/>
            <TextBlock Canvas.Left="590" Canvas.Top="302" Text="pornire P1"
                       Foreground="#22C55E" FontSize="9" Opacity="0.7"/>

            <!-- B4 redundanta B1 (gri) Canvas.Top=320 -->
