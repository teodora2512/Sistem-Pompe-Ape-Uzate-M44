                       Foreground="#AAAAAA" FontSize="11"/>
            <Line X1="578" Y1="325" X2="590" Y2="325" Stroke="#AAAAAA" StrokeThickness="1.5"/>
            <Line X1="578" Y1="331" X2="590" Y2="331" Stroke="#AAAAAA" StrokeThickness="1.5"/>
            <Ellipse Canvas.Left="574" Canvas.Top="322" Width="10" Height="10"
                     Stroke="#AAAAAA" StrokeThickness="1.5" Fill="Transparent"/>
            <Line X1="122" Y1="328" X2="580" Y2="328" Stroke="#AAAAAA"
                  StrokeThickness="0.5" StrokeDashArray="3,6" Opacity="0.3"/>
            <TextBlock Canvas.Left="125" Canvas.Top="320" Text="redundanta B1"
                       Foreground="#AAAAAA" FontSize="9" Opacity="0.5"/>

            <!-- B1 nivel minim (albastru) Canvas.Top=370 -->
            <TextBlock Canvas.Left="82" Canvas.Top="364" Text="B1"
                       Foreground="#3B82F6" FontSize="11" FontWeight="Bold"/>
            <Line X1="108" Y1="375" X2="120" Y2="375" Stroke="#3B82F6" StrokeThickness="1.5"/>
            <Line X1="108" Y1="381" X2="120" Y2="381" Stroke="#3B82F6" StrokeThickness="1.5"/>
            <Ellipse Canvas.Left="116" Canvas.Top="372" Width="10" Height="10"
                     Stroke="#3B82F6" StrokeThickness="1.5" Fill="Transparent"/>
            <Line X1="122" Y1="378" X2="580" Y2="378" Stroke="#3B82F6"
                  StrokeThickness="0.5" StrokeDashArray="6,4" Opacity="0.5"/>
            <TextBlock Canvas.Left="590" Canvas.Top="372" Text="oprire pompe"
                       Foreground="#3B82F6" FontSize="9" Opacity="0.7"/>
            <Canvas Canvas.Left="0">
                <Canvas.Style>
                    <Style TargetType="Canvas">
                        <Setter Property="Canvas.Top" Value="300"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalogModeActive}" Value="True">
                                <Setter Property="Canvas.Top" Value="{Binding LevelB2Top}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Canvas.Style>

                <TextBlock Canvas.Left="82" Canvas.Top="-11" Text="B2"
               Foreground="#22C55E" FontSize="11" FontWeight="Bold"/>
                <Line X1="108" Y1="0" X2="120" Y2="0" Stroke="#22C55E" StrokeThickness="1.5"/>
                <Line X1="108" Y1="6" X2="120" Y2="6" Stroke="#22C55E" StrokeThickness="1.5"/>
                <Ellipse Canvas.Left="116" Canvas.Top="-3" Width="10" Height="10"
             Stroke="#22C55E" StrokeThickness="1.5" Fill="Transparent"/>
                <Line X1="122" Y1="3" X2="580" Y2="3" Stroke="#22C55E"
          StrokeThickness="0.5" StrokeDashArray="6,4" Opacity="0.5"/>
                <TextBlock Canvas.Left="590" Canvas.Top="-3" Text="pornire P1(analog)"
               Foreground="#22C55E" FontSize="9" Opacity="0.7"/>
            </Canvas>

            <Canvas Canvas.Left="0">
                <Canvas.Style>
                    <Style TargetType="Canvas">
                        <Setter Property="Canvas.Top" Value="220"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnalogModeActive}" Value="True">
                                <Setter Property="Canvas.Top" Value="{Binding LevelB5Top}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Canvas.Style>

                <TextBlock Canvas.Left="588" Canvas.Top="-13" Text="B5"
               Foreground="#F59E0B" FontSize="11" FontWeight="Bold"/>
                <Line X1="578" Y1="-3" X2="590" Y2="-3" Stroke="#F59E0B" StrokeThickness="1.5"/>
                <Line X1="578" Y1="3" X2="590" Y2="3" Stroke="#F59E0B" StrokeThickness="1.5"/>
                <Ellipse Canvas.Left="574" Canvas.Top="-6" Width="10" Height="10"
             Stroke="#F59E0B" StrokeThickness="1.5" Fill="Transparent"/>
                <Line X1="122" Y1="0" X2="580" Y2="0" Stroke="#F59E0B"
          StrokeThickness="0.5" StrokeDashArray="6,4" Opacity="0.5"/>
                <TextBlock Canvas.Left="125" Canvas.Top="-6" Text="↑ pornire P2(analog)"
               Foreground="#F59E0B" FontSize="9" Opacity="0.7"/>
            </Canvas>

            <!-- === POMPA M1 === -->
            <Ellipse Canvas.Left="178" Canvas.Top="408" Width="64" Height="64"
                     Fill="#2D2D2D" Stroke="#666666" StrokeThickness="2"/>
            <TextBlock Canvas.Left="199" Canvas.Top="433" Text="M1"
                       Foreground="#CCCCCC" FontSize="13" FontWeight="Bold"/>
            <Ellipse Canvas.Left="227" Canvas.Top="412" Width="11" Height="11"
                     Fill="#22C55E" Stroke="#16A34A" StrokeThickness="1"
                     Visibility="{Binding Pump1Visibility}"/>
            <Ellipse Canvas.Left="227" Canvas.Top="412" Width="11" Height="11"
                     Fill="#444444" Stroke="#555555" StrokeThickness="1"
                     Visibility="{Binding Pump1HiddenVisibility}"/>
            <!-- Lampa P3 -->
            <Ellipse Canvas.Left="178" Canvas.Top="400" Width="10" Height="10"
                     Stroke="#888888" StrokeThickness="1">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#333333"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPump1Running}" Value="True">
                                <Setter Property="Fill" Value="#22C55E"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Canvas.Left="190" Canvas.Top="398" Text="P3" Foreground="#888888" FontSize="9"/>
            <Line X1="210" Y1="408" X2="210" Y2="400" Stroke="#555555"
                  StrokeThickness="2" StrokeDashArray="4,3"/>
            <Line X1="210" Y1="472" X2="210" Y2="500" Stroke="#777777" StrokeThickness="4"/>

            <!-- === POMPA M2 === -->
            <Ellipse Canvas.Left="458" Canvas.Top="408" Width="64" Height="64"
                     Fill="#2D2D2D" Stroke="#666666" StrokeThickness="2"/>
            <TextBlock Canvas.Left="479" Canvas.Top="433" Text="M2"
                       Foreground="#CCCCCC" FontSize="13" FontWeight="Bold"/>
            <Ellipse Canvas.Left="507" Canvas.Top="412" Width="11" Height="11"
                     Fill="#22C55E" Stroke="#16A34A" StrokeThickness="1"
                     Visibility="{Binding Pump2Visibility}"/>
            <Ellipse Canvas.Left="507" Canvas.Top="412" Width="11" Height="11"
                     Fill="#444444" Stroke="#555555" StrokeThickness="1"
                     Visibility="{Binding Pump2HiddenVisibility}"/>
            <!-- Lampa P4 -->
            <Ellipse Canvas.Left="458" Canvas.Top="400" Width="10" Height="10"
                     Stroke="#888888" StrokeThickness="1">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#333333"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPump2Running}" Value="True">
                                <Setter Property="Fill" Value="#22C55E"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Canvas.Left="470" Canvas.Top="398" Text="P4" Foreground="#888888" FontSize="9"/>
            <Line X1="490" Y1="472" X2="490" Y2="500" Stroke="#777777" StrokeThickness="4"/>

            <!-- === CONDUCTA COLECTOARE JOS === -->
            <Line X1="140" Y1="500" X2="560" Y2="500" Stroke="#777777" StrokeThickness="5"/>
            <Line X1="140" Y1="500" X2="140" Y2="516" Stroke="#777777" StrokeThickness="4"/>
            <Line X1="560" Y1="500" X2="560" Y2="516" Stroke="#777777" StrokeThickness="4"/>
            <Line X1="120" Y1="516" X2="580" Y2="516" Stroke="#777777" StrokeThickness="5"/>
            <Polygon Points="295,508 315,516 295,524" Fill="#777777"/>

            <!-- === INDICATOARE === -->
            <!-- Alarma vizuala -->
            <Ellipse Canvas.Left="312" Canvas.Top="128" Width="30" Height="30"
                     Fill="#EF4444" Visibility="{Binding AlarmVisibility}"/>
            <TextBlock Canvas.Left="298" Canvas.Top="162" Text="! ALARMA"
                       Foreground="#EF4444" FontSize="11" FontWeight="Bold"
                       Visibility="{Binding AlarmVisibility}"/>
            <!-- Alarma sonora 5s -->
            <Border Canvas.Left="230" Canvas.Top="128" Width="130" Height="26"
                    Background="#7F1D1D" CornerRadius="4"
                    Visibility="{Binding AlarmSoundingVisibility}">
                <TextBlock Text="ALARMA ACTIVA 5s" Foreground="#FCA5A5"
                           FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <!-- Sistem pornit -->
            <Ellipse Canvas.Left="128" Canvas.Top="126" Width="16" Height="16"
                     Fill="#22C55E" Visibility="{Binding SystemOnVisibility}"/>
            <TextBlock Canvas.Left="126" Canvas.Top="146" Text="ON"
                       Foreground="#22C55E" FontSize="10"
                       Visibility="{Binding SystemOnVisibility}"/>
            <!-- Indicator MOD ANALOGIC activ -->
<Border Canvas.Left="350" Canvas.Top="126" Width="110" Height="20"
        Background="#78350F" CornerRadius="4"
        Visibility="{Binding IsAnalogModeActive, Converter={StaticResource BoolToVisibility}}">
    <TextBlock Text="MOD ANALOGIC" Foreground="#FCD34D"
               FontSize="9" FontWeight="Bold"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
</Border>

        </Canvas>

        <!-- ==================== PANOUL DE CONTROL ==================== -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                Background="#1E1E2E" BorderBrush="#444444" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,8,0,8" RenderTransformOrigin="-6.501,-0.071">

                    <TextBlock Text="Control" Foreground="#DDDDDD" FontSize="13"
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <Separator Background="#444444" Margin="8,0"/>

                    <!-- Indicatoare S0/S1 -->
                    <StackPanel Orientation="Horizontal" Margin="8,6,8,2">
                        <Ellipse Width="12" Height="12" Fill="#555555" Stroke="#888888"
                                 StrokeThickness="1" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="S0  Aus/Off" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="8,2,8,6">
                        <Ellipse Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center" StrokeThickness="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#555555"/>
                                    <Setter Property="Stroke" Value="#888888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSystemOn}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                            <Setter Property="Stroke" Value="#16A34A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="S1  Ein/On" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Indicatoare H3/S3 H4/S4 -->
                    <StackPanel Orientation="Horizontal" Margin="8,2,8,2">
                        <Ellipse Width="8" Height="8" Fill="#555555" Stroke="#777777"
                                 StrokeThickness="1" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Text="H3 " Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                        <Ellipse Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center" StrokeThickness="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#555555"/>
                                    <Setter Property="Stroke" Value="#888888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPump1Running}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                            <Setter Property="Stroke" Value="#16A34A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="S3  Pompa 1" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="8,2,8,6">
                        <Ellipse Width="8" Height="8" Fill="#555555" Stroke="#777777"
                                 StrokeThickness="1" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Text="H4 " Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                        <Ellipse Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center" StrokeThickness="1">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#555555"/>
                                    <Setter Property="Stroke" Value="#888888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPump2Running}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                            <Setter Property="Stroke" Value="#16A34A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="S4  Pompa 2" Foreground="#888888" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Background="#333333" Margin="8,2"/>


                    <!-- BUTOANE PRINCIPALE -->
                    <TextBlock Text="Comenzi principale" Foreground="#666666"
                               FontSize="10" Margin="8,6,8,2" FontStyle="Italic"/>

                    <Button Style="{StaticResource ControlButton}"
                            Background="#15803D" Click="Button_Click_S1_On">
                        <TextBlock Text="S1 — Pornire sistem"/>
                    </Button>
                    <Button Style="{StaticResource ControlButton}"
                            Background="#7F1D1D" Click="Button_Click_S0_Off">
                        <TextBlock Text="S0 — Oprire sistem"/>
                    </Button>

                    <Separator Background="#333333" Margin="8,4"/>

                    <!-- TESTE POMPE -->
                    <TextBlock Text="Test pompe (3 secunde)" Foreground="#666666"
                               FontSize="10" Margin="8,4,8,2" FontStyle="Italic"/>

                    <Button Style="{StaticResource ControlButton}"
                            Background="#1D4ED8" Click="Button_Click_S3_TestP1">
                        <TextBlock Text="S3 — Test Pompa 1 / Set Prag P1"/>
                    </Button>
                    <Button Style="{StaticResource ControlButton}"
                            Background="#1D4ED8" Click="Button_Click_S4_TestP2">
                        <TextBlock Text="S4 — Test Pompa 2 / Set Prag P2"/>
                    </Button>

                    <Separator Background="#333333" Margin="8,4"/>

                    <!-- RESET -->
                    <Button Style="{StaticResource ControlButton}"
                            Background="#C2410C" Click="Button_Click_S5_Reset">
                        <TextBlock Text="S5 — Reset alarma"/>
                    </Button>
                    <Separator Background="#FFCC00" Height="2" Margin="8,10"/>
                    <TextBlock Text="MOD ANALOGIC" Foreground="#FFCC00" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <CheckBox Content="Activare Reglaj Analogic" IsChecked="{Binding IsAnalogModeActive, Mode=TwoWay}" Foreground="White" FontSize="11" Margin="12,2,0,10"/>

                    <TextBlock Text="Y Zulauf / Inflow" Foreground="#E0E0E0" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                    <Slider Minimum="0" Maximum="10" Value="{Binding PotentiometerVoltage1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Opacity="0.01" Width="60" Height="60"/>
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,10" Width="66" Height="66"
                      MouseLeftButtonDown="Potentiometer1_MouseLeftButtonDown"
                      MouseMove="Potentiometer1_MouseMove"
                      MouseLeftButtonUp="Potentiometer1_MouseLeftButtonUp"
                      MouseWheel="Potentiometer1_MouseWheel">
                        <Ellipse Width="65" Height="65" Stroke="#555555" StrokeThickness="1" StrokeDashArray="3,3"/>
                        <Ellipse Width="50" Height="50" Fill="#252535" Stroke="#888888" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Grid Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid.RenderTransform>
                                <RotateTransform Angle="{Binding Potentiometer1Angle, FallbackValue=0}" CenterX="25" CenterY="25"/>
                            </Grid.RenderTransform>
                            <Line X1="25" Y1="25" X2="25" Y2="4" Stroke="#EF4444" StrokeThickness="3" StrokeEndLineCap="Round"/>
                        </Grid>
                        <Slider Minimum="0" Maximum="10" Value="{Binding PotentiometerVoltage1, Mode=TwoWay}" Opacity="0.01" Width="60" Height="60"/>
                    </Grid>
                    <TextBlock Text="{Binding PotentiometerVoltage1, StringFormat={}{0:F1} V}" Foreground="#FF5722" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,2">
                        <TextBlock Text="U2" FontSize="11" FontWeight="Bold" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                        <TextBlock Text=" Soll-Pegel / Setpoint level" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,15" Width="66" Height="66"
                      MouseLeftButtonDown="Potentiometer2_MouseLeftButtonDown"
                      MouseMove="Potentiometer2_MouseMove"
                      MouseLeftButtonUp="Potentiometer2_MouseLeftButtonUp"
                      MouseWheel="Potentiometer2_MouseWheel">
                        <Ellipse Width="65" Height="65" Stroke="#555555" StrokeThickness="1" StrokeDashArray="3,3"/>
                        <Ellipse Width="50" Height="50" Fill="#252535" Stroke="#888888" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <Grid Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid.RenderTransform>
                                <RotateTransform Angle="{Binding Potentiometer2Angle, FallbackValue=0}" CenterX="25" CenterY="25"/>
                            </Grid.RenderTransform>
                            <Line X1="25" Y1="25" X2="25" Y2="4" Stroke="#3B82F6" StrokeThickness="3" StrokeEndLineCap="Round"/>
                        </Grid>

                        <Slider Minimum="0" Maximum="10" Value="{Binding PotentiometerVoltage2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Opacity="0.01" Width="60" Height="60"/>
                    </Grid>
                    <TextBlock Text="{Binding PotentiometerVoltage2, StringFormat={}{0:F1} V}" Foreground="#2196F3" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Separator Background="#444444" Margin="8,5"/>


                    <!-- SIMULARI -->
                    <TextBlock Text="Simulari scenarii" Foreground="#666666"
                               FontSize="10" Margin="8,4,8,2" FontStyle="Italic"/>

                    <!-- Simuleaza rata admisie mare → testeaza B5 si P2 -->
                    <Button Style="{StaticResource SimButton}"
                            Background="#92400E" Click="Button_Click_HighInflow">
                        <StackPanel>
                            <TextBlock Text="Rata admisie MARE" FontWeight="Bold"/>
                            <TextBlock Text="→ testeaza B5 si P2" FontSize="9" Opacity="0.8"/>
                        </StackPanel>
                    </Button>

                    <!-- Revine la rata normala -->
                    <Button Style="{StaticResource SimButton}"
                            Background="#374151" Click="Button_Click_NormalInflow">
                        <StackPanel>
                            <TextBlock Text="Rata admisie normala"/>
                            <TextBlock Text="→ P1 face fata singur" FontSize="9" Opacity="0.8"/>
                        </StackPanel>
                    </Button>

                    <!-- Simuleaza B1 defect → testeaza B4 -->
                    <Button Style="{StaticResource SimButton}"
                            Background="#581C87" Click="Button_Click_B1Defect">
                        <StackPanel>
                            <TextBlock Text="B1 DEFECT (activ B4)" FontWeight="Bold"/>
                            <TextBlock Text="→ testeaza redundanta B4" FontSize="9" Opacity="0.8"/>
                        </StackPanel>
                    </Button>

                    <!-- Revine la B1 normal -->
                    <Button Style="{StaticResource SimButton}"
                            Background="#374151" Click="Button_Click_B1Normal">
                        <StackPanel>
                            <TextBlock Text="B1 normal (reset)"/>
                            <TextBlock Text="→ oprire la B1 din nou" FontSize="9" Opacity="0.8"/>
                        </StackPanel>
                    </Button>

                    <!-- Simuleaza alarma releu -->
                    <Button Style="{StaticResource SimButton}"
                            Background="#6B21A8" Click="Button_Click_SimulateAlarm">
                        <StackPanel>
                            <TextBlock Text="! Releu protectie" FontWeight="Bold"/>
                            <TextBlock Text="→ testeaza B3 + alarma" FontSize="9" Opacity="0.8"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="#333333" Margin="8,4"/>

                    <!-- Legenda senzori -->
                    <TextBlock Text="Legenda senzori" Foreground="#666666"
                               FontSize="10" Margin="8,2,8,2" FontStyle="Italic"/>
                    <StackPanel Orientation="Horizontal" Margin="8,1">
                        <Ellipse Width="7" Height="7" Fill="#EF4444" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="B3 — nivel critic" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="8,1">
                        <Ellipse Width="7" Height="7" Fill="#F59E0B" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="B5 — pornire P2" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="8,1">
                        <Ellipse Width="7" Height="7" Fill="#22C55E" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="B2 — pornire P1" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="8,1">
                        <Ellipse Width="7" Height="7" Fill="#AAAAAA" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="B4 — redundanta B1" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="8,1">
                        <Ellipse Width="7" Height="7" Fill="#3B82F6" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="B1 — oprire pompe" Foreground="#666666" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="#111111" BorderBrush="#333333" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusLabel"
                       Text="Status: Sistem oprit. Apasa S1 pentru pornire."
                       Foreground="#777777" FontSize="12"
                       VerticalAlignment="Center" Margin="15,0"/>
        </Border>

    </Grid>
</UserControl>